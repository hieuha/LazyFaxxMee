# ============================================
# LazyFax — .gitignore
# ============================================

# -------- OS / editor --------
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/
!.vscode/extensions.json

# -------- Secrets --------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
credentials.json
serviceAccount.json

# -------- Python (backend + agent) --------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.egg-info/
build/
dist/
*.egg
.tox/
.nox/
pip-wheel-metadata/

# -------- Node / Web --------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Vite / bundlers
web/dist/
web/.vite/
*.tsbuildinfo

# -------- Docker / deploy --------
docker-compose.override.yml
deploy/cloudflared-config.yml
!deploy/cloudflared-config.example.yml

# -------- Media & runtime data --------
backend/media/
media/
*.escpos
!backend/tests/fixtures/*.escpos
logs.txt
*.log

# -------- Agent build artifacts --------
agent/build/dist/
agent/build/*.spec.tmp
agent/dist/
agent/*.dmg
agent/*.pkg
agent/*.exe
agent/*.msi
agent/*.AppImage

# -------- Claude Code / ClaudeKit runtime --------
# Track only the rule contract; the rest is installed via `ck install`
/.claude/
!/.claude/rules/

# ClaudeKit meta commands (generated on demand)
prompt.md
ck.md
release-manifest.json

# -------- Repomix / research tools --------
repomix-output.xml
.serena/cache/
external/
worktrees/

# -------- Plans/reports policy --------
# Plans and reports are local-only planning artifacts, not shipped source.
plans/

# -------- Claude Code root guide (local-only) --------
CLAUDE.md

# -------- Misc --------
test-ck/
screenshots/
docs/screenshots/
