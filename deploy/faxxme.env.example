# FaxxMe service configuration.
# install.sh copies this to deploy/faxxme.env (edit that, then: sudo systemctl restart faxxme)

FAXXME_HOST=0.0.0.0
FAXXME_PORT=8000
FAXXME_LOG_LEVEL=info

# Callsign whose faxes print on THIS host's wired-in printer (the "local bridge").
# Leave blank to disable server-side printing (pure browser/WebUSB mode).
FAXXME_LOCAL_USER=pi
FAXXME_PRINTER_DEV=/dev/usb/lp0
# how often (seconds) to check for a hot-replugged printer and flush the queue
FAXXME_PRINTER_POLL=4

# Receipt geometry: 58mm printer = 32 chars / 384 dots, 80mm = 48 / 576.
FAXXME_WIDTH=32
FAXXME_PRINT_DOTS=384

# Paper cut at the end of each fax:
#   full    = feed a little + full cut (default; tear-off printers just ignore the cut)
#   feed    = feed to the cutter + full cut (cleanest & least paper IF the printer has a cutter)
#   partial = feed a little + partial cut
#   none    = no cut, feed for manual tear-off
FAXXME_CUT=full

# Anti-spam: max faxes a user can send per window (0 = unlimited)
FAXXME_FAX_RATE_MAX=20
FAXXME_FAX_RATE_WINDOW=60
