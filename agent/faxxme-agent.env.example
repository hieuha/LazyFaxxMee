# FaxxMe printer-agent config. install.sh copies this to faxxme-agent.env — edit that,
# then: sudo systemctl restart faxxme-agent

# The FaxxMe server you fax through (HTTPS strongly recommended over the internet).
FAXXME_SERVER=https://your-faxxme-server.example

# Your account.
FAXXME_AGENT_USER=your_callsign

# Device token from the web: log in → :: PRINTER NODE → GENERATE TOKEN → copy it here.
# Regenerating on the web revokes this one.
FAXXME_AGENT_TOKEN=paste-your-device-token-here

# Local printer.
FAXXME_PRINTER_DEV=/dev/usb/lp0
FAXXME_PRINTER_POLL=4
